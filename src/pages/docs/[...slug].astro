---
import { Content } from "@layouts";
import { getCollection, render } from "astro:content";
import { buildDocsSidebar } from "@lib/sidebar";

export async function getStaticPaths() {
  const COLLECTIONS = ["notes", "portfolio", "sandbox", "automation"] as const;
  const allEntries = await Promise.all(
    COLLECTIONS.map((col) =>
      getCollection(col, ({ data }) => !data.draft).then((entries) =>
        entries.map((entry) => ({
          params: { slug: `${col}/${entry.id.replace(/\/index$/, "")}` },
          props: { entry, collection: col },
        })),
      ),
    ),
  );
  return allEntries.flat();
}

const { entry } = Astro.props;
const currentPath = Astro.url.pathname;
const { Content: Body, headings } = await render(entry);
const sidebar = await buildDocsSidebar(currentPath);
---

<Content
  title={entry.data.title}
  description={entry.data.description}
  sidebar={sidebar}
  headings={headings}
>
  <Body />
</Content>
