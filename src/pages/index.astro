---
import { Base } from "@layouts";
import { getFeaturedProjects, getRecentNotes } from "@lib/collections";
import { HomePage } from "@pages/HomePage";

const projects = await getFeaturedProjects();
const serializedProjects = projects.map((e) => ({ id: e.id, data: e.data }));

const recentNotes = await getRecentNotes(4);
const serializedNotes = recentNotes.map((e) => ({
  id: e.id,
  data: {
    title: e.data.title,
    description: e.data.description,
    pubDate: e.data.pubDate ?? null,
  },
}));
---

<Base>
  <HomePage client:load projects={serializedProjects} recentNotes={serializedNotes} />
</Base>
